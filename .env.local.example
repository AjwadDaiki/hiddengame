# ─── MONGODB ──────────────────────────────────────────────────────────────────
# Local MongoDB (installer: https://www.mongodb.com/try/download/community)
# La base de donnees est creee automatiquement au premier lancement
MONGODB_URI=mongodb://localhost:27017/arcadewave

# MongoDB Atlas (cloud gratuit 512MB) : https://www.mongodb.com/atlas
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/arcadewave

# ─── SITE ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=ArcadeWave

# ─── GAMEDISTRIBUTION ────────────────────────────────────────────────────────
# Cree ton compte publisher sur gamedistribution.com
# Apres approbation, recupere ton Publisher ID (32 chars) dans ton dashboard
NEXT_PUBLIC_GD_PUBLISHER_ID=

# ─── GOOGLE ANALYTICS ────────────────────────────────────────────────────────
# Optionnel - creer une propriete sur analytics.google.com
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── GOOGLE ADSENSE ──────────────────────────────────────────────────────────
# Optionnel - apres approbation AdSense
# NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXX
