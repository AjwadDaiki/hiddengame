# ─── SUPABASE ────────────────────────────────────────────────────────────────
# Créer un projet sur https://supabase.com (gratuit)
# Settings → API → URL et anon key
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── GAMEDISTRIBUTION ────────────────────────────────────────────────────────
# S'inscrire sur https://gamedistribution.com (gratuit, approbation sous 24h)
# Dashboard → Publisher ID
NEXT_PUBLIC_GD_PUBLISHER_ID=your_publisher_id_here

# ─── SITE ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://arcadewave.gg
NEXT_PUBLIC_SITE_NAME=ArcadeWave

# ─── GOOGLE ANALYTICS ────────────────────────────────────────────────────────
# Optionnel - créer une propriété sur analytics.google.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── GOOGLE ADSENSE ──────────────────────────────────────────────────────────
# Optionnel - après approbation AdSense
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXX
